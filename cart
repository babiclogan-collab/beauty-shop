<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart — LUMÉ</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --obsidian: #0A0709;
    --void: #110D12;
    --deep: #1A1020;
    --amethyst: #3D1F5C;
    --violet: #6B3FA0;
    --smoke: #C8B8D8;
    --mist: #E8E0F0;
    --ember: #D4A853;
    --crimson: #8B2252;
    --text: #E8E0F0;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--obsidian);
    color: var(--text);
    overflow-x: hidden;
  }

  .float-nav {
    position: fixed; top: 24px; left: 50%; transform: translateX(-50%);
    background: rgba(10, 7, 9, 0.88); backdrop-filter: blur(16px);
    border: 1px solid rgba(107, 63, 160, 0.3);
    border-radius: 50px; padding: 14px 32px;
    display: flex; align-items: center; gap: 32px; z-index: 100;
  }
  .float-nav a {
    color: var(--smoke); text-decoration: none; font-size: 0.78rem;
    letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7;
    transition: opacity 0.2s, color 0.2s;
  }
  .float-nav a:hover { opacity: 1; color: var(--mist); }
  .float-nav a.active { opacity: 1; color: var(--ember); }
  .float-nav .nav-logo {
    font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600;
    letter-spacing: 0.2em; color: var(--ember);
  }

  .cart-header {
    padding: 160px 80px 50px;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--ember); margin-bottom: 16px; font-weight: 500;
  }

  .cart-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300; color: var(--mist);
  }
  .cart-header h1 em { font-style: italic; color: var(--violet); }

  .cart-wrap {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 48px;
    padding: 0 80px 120px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }

  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    align-items: center;
    gap: 24px;
    background: var(--deep);
    border: 1px solid rgba(107, 63, 160, 0.2);
    border-radius: 16px;
    padding: 20px;
  }

  .item-thumb {
    width: 100px; height: 100px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }

  .bg-1 { background: radial-gradient(ellipse at 50% 60%, #3D1F5C 0%, #1A1020 100%); }
  .bg-2 { background: radial-gradient(ellipse at 50% 60%, #5C1F3D 0%, #1A1020 100%); }
  .bg-3 { background: radial-gradient(ellipse at 50% 60%, #2A1F5C 0%, #0A0709 100%); }

  .mini-serum .ms-body { width: 32px; height: 70px; background: linear-gradient(160deg, #3D1F5C, #6B3FA0); border-radius: 16px 16px 9px 9px; }
  .mini-serum .ms-dropper { width: 10px; height: 18px; background: linear-gradient(to bottom, #0A0709, #1A1020); border-radius: 2px 2px 0 0; margin: 0 auto; }
  .mini-serum .ms-tip { width: 4px; height: 7px; background: var(--ember); border-radius: 0 0 2px 2px; margin: 0 auto; }

  .mini-cream .mc-lid { width: 50px; height: 11px; background: linear-gradient(135deg, #0A0709, #1A1020); border-radius: 4px 4px 0 0; margin: 0 auto; }
  .mini-cream .mc-body { width: 58px; height: 32px; background: linear-gradient(135deg, #3D1F5C, #6B3FA0); border-radius: 3px 3px 8px 8px; }

  .mini-mist .mm-body { width: 40px; height: 62px; background: linear-gradient(135deg, #2A1640, #5C1F3D); border-radius: 6px; }
  .mini-mist .mm-head { width: 22px; height: 14px; background: linear-gradient(135deg, #0A0709, #1A1020); border-radius: 2px; margin: 0 auto; }
  .mini-mist .mm-nozzle { width: 6px; height: 8px; background: var(--ember); border-radius: 0 0 2px 0; margin-left: auto; margin-right: 4px; }

  .item-info h4 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; font-weight: 400; color: var(--mist); margin-bottom: 4px;
  }
  .item-info p { font-size: 0.78rem; color: rgba(200,184,216,0.45); }

  .item-qty {
    display: flex; align-items: center; gap: 0;
    border: 1px solid rgba(107, 63, 160, 0.3);
    border-radius: 50px; overflow: hidden;
  }
  .item-qty button {
    width: 32px; height: 32px; background: transparent; border: none;
    color: var(--mist); cursor: pointer; font-size: 0.95rem; transition: background 0.2s;
  }
  .item-qty button:hover { background: rgba(107,63,160,0.2); }
  .item-qty span { width: 28px; text-align: center; font-size: 0.85rem; }

  .item-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem; color: var(--ember); text-align: right; min-width: 60px;
  }

  .remove-btn {
    grid-column: 1 / -1;
    text-align: right;
    background: none; border: none;
    color: rgba(200,184,216,0.35);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    text-decoration: underline;
    margin-top: -8px;
  }
  .remove-btn:hover { color: var(--crimson); }

  .empty-cart {
    text-align: center;
    padding: 60px 20px;
    color: rgba(200,184,216,0.4);
    font-size: 0.9rem;
    display: none;
  }

  /* SUMMARY */
  .summary-card {
    background: var(--deep);
    border: 1px solid rgba(107, 63, 160, 0.2);
    border-radius: 20px;
    padding: 36px;
    position: sticky;
    top: 110px;
  }

  .summary-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 400; color: var(--mist); margin-bottom: 24px;
  }

  .summary-row {
    display: flex; justify-content: space-between;
    font-size: 0.85rem; color: rgba(200,184,216,0.6);
    margin-bottom: 16px;
  }

  .summary-row.total {
    border-top: 1px solid rgba(107, 63, 160, 0.2);
    padding-top: 18px;
    margin-top: 18px;
    font-size: 1.1rem;
    color: var(--mist);
  }
  .summary-row.total span:last-child { color: var(--ember); font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; }

  .promo-row {
    display: flex;
    gap: 10px;
    margin: 24px 0;
  }
  .promo-row input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid rgba(107, 63, 160, 0.3);
    border-radius: 10px;
    background: rgba(10, 7, 9, 0.6);
    color: var(--mist);
    font-size: 0.82rem;
    outline: none;
  }
  .promo-row input::placeholder { color: rgba(200,184,216,0.3); }
  .promo-row button {
    padding: 12px 20px;
    background: transparent;
    border: 1px solid rgba(212, 168, 83, 0.4);
    color: var(--ember);
    border-radius: 10px;
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.2s;
  }
  .promo-row button:hover { background: rgba(212,168,83,0.1); }

  .checkout-btn {
    width: 100%;
    background: var(--amethyst);
    border: 1px solid rgba(107, 63, 160, 0.5);
    color: var(--mist);
    padding: 18px;
    font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase;
    border-radius: 50px; font-weight: 500; cursor: pointer;
    transition: background 0.25s, box-shadow 0.25s;
    margin-top: 8px;
  }
  .checkout-btn:hover { background: var(--violet); box-shadow: 0 8px 32px rgba(107,63,160,0.4); }

  .secure-note {
    text-align: center;
    font-size: 0.72rem;
    color: rgba(200,184,216,0.35);
    margin-top: 16px;
  }

  footer {
    background: #050305;
    border-top: 1px solid rgba(107, 63, 160, 0.15);
    padding: 60px 80px 40px;
    color: rgba(200, 184, 216, 0.35);
    text-align: center;
  }
  .footer-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 600; letter-spacing: 0.2em; color: var(--ember); margin-bottom: 12px;
  }
  .footer-bottom-text { font-size: 0.75rem; margin-top: 24px; }

  @media (max-width: 900px) {
    .cart-header { padding: 130px 36px 40px; }
    .cart-wrap { grid-template-columns: 1fr; padding: 0 36px 80px; gap: 32px; }
    .cart-item { grid-template-columns: 70px 1fr; }
    .item-qty, .item-price { grid-column: 2; justify-self: start; }
    .summary-card { position: static; }
  }
</style>
</head>
<body>

<nav class="float-nav">
  <a href="beauty-shop.html" class="nav-logo">LUMÉ</a>
  <a href="shop.html">Shop</a>
  <a href="about.html">About</a>
  <a href="contact.html">Contact</a>
  <a href="cart.html" class="active">Cart</a>
</nav>

<div class="cart-header">
  <p class="eyebrow">Your Selection</p>
  <h1>Almost <em>yours</em></h1>
</div>

<div class="cart-wrap">
  <div class="cart-items" id="cartItems">
    <div class="cart-item" data-price="68">
      <div class="item-thumb bg-1">
        <div class="mini-serum"><div class="ms-dropper"></div><div class="ms-tip"></div><div class="ms-body"></div></div>
      </div>
      <div class="item-info">
        <h4>Radiance Serum</h4>
        <p>30ml</p>
      </div>
      <div class="item-qty">
        <button class="qm">−</button>
        <span class="qv">1</span>
        <button class="qp">+</button>
      </div>
      <div class="item-price">$68</div>
      <button class="remove-btn">Remove</button>
    </div>

    <div class="cart-item" data-price="84">
      <div class="item-thumb bg-2">
        <div class="mini-cream"><div class="mc-lid"></div><div class="mc-body"></div></div>
      </div>
      <div class="item-info">
        <h4>Velvet Repair Cream</h4>
        <p>50ml</p>
      </div>
      <div class="item-qty">
        <button class="qm">−</button>
        <span class="qv">1</span>
        <button class="qp">+</button>
      </div>
      <div class="item-price">$84</div>
      <button class="remove-btn">Remove</button>
    </div>

    <div class="cart-item" data-price="42">
      <div class="item-thumb bg-3">
        <div class="mini-mist"><div class="mm-nozzle"></div><div class="mm-head"></div><div class="mm-body"></div></div>
      </div>
      <div class="item-info">
        <h4>Dew Mist</h4>
        <p>100ml</p>
      </div>
      <div class="item-qty">
        <button class="qm">−</button>
        <span class="qv">1</span>
        <button class="qp">+</button>
      </div>
      <div class="item-price">$42</div>
      <button class="remove-btn">Remove</button>
    </div>
  </div>

  <div class="empty-cart" id="emptyCart">Your cart is empty. <a href="shop.html" style="color: var(--ember);">Browse the shop →</a></div>

  <div class="summary-card">
    <h3>Order Summary</h3>
    <div class="summary-row">
      <span>Subtotal</span>
      <span id="subtotal">$194.00</span>
    </div>
    <div class="summary-row">
      <span>Shipping</span>
      <span>Free</span>
    </div>
    <div class="promo-row">
      <input type="text" placeholder="Promo code">
      <button>Apply</button>
    </div>
    <div class="summary-row total">
      <span>Total</span>
      <span id="total">$194.00</span>
    </div>
    <button class="checkout-btn">Proceed to Checkout</button>
    <p class="secure-note">🔒 Secure checkout · Visual demo only</p>
  </div>
</div>

<footer>
  <div class="footer-brand-name">LUMÉ</div>
  <div class="footer-bottom-text">© 2026 LUMÉ Beauty. All rights reserved.</div>
</footer>

<script>
  function recalc() {
    let subtotal = 0;
    document.querySelectorAll('.cart-item').forEach(item => {
      const price = parseFloat(item.dataset.price);
      const qty = parseInt(item.querySelector('.qv').textContent);
      const linePrice = price * qty;
      item.querySelector('.item-price').textContent = '$' + linePrice.toFixed(2);
      subtotal += linePrice;
    });
    document.getElementById('subtotal').textContent = '$' + subtotal.toFixed(2);
    document.getElementById('total').textContent = '$' + subtotal.toFixed(2);

    const items = document.querySelectorAll('.cart-item');
    document.getElementById('emptyCart').style.display = items.length === 0 ? 'block' : 'none';
  }

  document.querySelectorAll('.qp').forEach(btn => {
    btn.addEventListener('click', () => {
      const span = btn.previousElementSibling;
      span.textContent = parseInt(span.textContent) + 1;
      recalc();
    });
  });

  document.querySelectorAll('.qm').forEach(btn => {
    btn.addEventListener('click', () => {
      const span = btn.nextElementSibling;
      let val = parseInt(span.textContent);
      if (val > 1) { span.textContent = val - 1; recalc(); }
    });
  });

  document.querySelectorAll('.remove-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.cart-item').remove();
      recalc();
    });
  });

  document.querySelector('.checkout-btn').addEventListener('click', function() {
    const orig = this.textContent;
    this.textContent = 'This is a visual demo';
    setTimeout(() => { this.textContent = orig; }, 2000);
  });
</script>
</body>
</html>
